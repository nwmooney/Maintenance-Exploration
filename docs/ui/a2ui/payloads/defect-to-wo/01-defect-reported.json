{
  "type": "surface",
  "id": "defect_new_surface",
  "components": [
    {
      "type": "CMXCard",
      "title": "New Defect Reported",
      "status": "New",
      "assetId": "{{assetId}}",
      "timestamp": "{{reportedAt}}",
      "summary": "{{summary}}"
    },
    {
      "type": "ActionBar",
      "actions": [
        {
          "type": "CommandButton",
          "label": "Create Work Order",
          "intent": "POST /work-orders/drafts"
        },
        {
          "type": "CommandButton",
          "label": "View Details",
          "intent": "GET /defects/{{defectId}}"
        },
        {
          "type": "CommandButton",
          "label": "Snooze",
          "intent": "POST /defects/{{defectId}}/snooze"
        }
      ]
    }
  ]
}
