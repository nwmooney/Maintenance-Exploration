{
  "type": "surface",
  "id": "wo_active_surface",
  "components": [
    {
      "type": "CMXCard",
      "title": "Work Order Active",
      "status": "Open",
      "assetId": "{{assetId}}",
      "summary": "Work Order {{workOrderId}} is active"
    },
    {
      "type": "ActionBar",
      "actions": [
        {
          "type": "CommandButton",
          "label": "Assign Technician",
          "intent": "POST /work-orders/{{workOrderId}}/assign"
        },
        {
          "type": "CommandButton",
          "label": "Schedule",
          "intent": "POST /work-orders/{{workOrderId}}/schedule"
        }
      ]
    }
  ]
}
